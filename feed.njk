---
permalink: /feed.xml
eleventyExcludeFromCollections: true
---
<?xml version="1.0" encoding="utf-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
<channel>
  <title>{{ site.name }}</title>
  <link>{{ site.url }}</link>
  <description>{{ site.tagline }}</description>
  <language>en</language>
  <atom:link href="{{ site.url }}/feed.xml" rel="self" type="application/rss+xml"/>
  {%- for e in collections.log %}
  <item>
    <title>Observation log, day {{ e.data.day | dayNum }} — {{ e.data.rubric }}</title>
    <link>{{ site.url }}{{ e.url }}</link>
    <guid>{{ site.url }}{{ e.url }}</guid>
    <pubDate>{{ e.data.declassified | rssDate }}</pubDate>
    <description>{{ e.content | striptags | truncate(400) }}</description>
  </item>
  {%- endfor %}
</channel>
</rss>
