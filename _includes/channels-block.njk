<section class="channels corner">
  <p class="tag">INTERCEPT CHANNELS</p>
  <div class="chan-row">
    {% for c in site.channels %}
    <a class="btn" href="{{ c.url }}" rel="me">{{ c.label }} · {{ c.handle }}</a>
    {% endfor %}
    <a class="btn" href="{{ '/feed.xml' | url }}">RSS</a>
  </div>
  <form action="#" method="post" class="notify">
    <input type="email" name="email" placeholder="signal address (email)" aria-label="Email">
    <button class="btn" type="submit">NOTIFY</button>
  </form>
</section>
