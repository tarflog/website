---
layout: base.njk
---
<main class="wrap entry">
  <p class="meta"><span>DECLASSIFIED {{ declassified | isoDate }}</span>{% if incident %}<span class="inc-tag">INCIDENT № {{ incident | pad2 }}</span>{% endif %}</p>
  <h1>FRAGMENT {{ file }} <span class="r">· {{ rubric }}</span></h1>
  <p class="dateline">LOG DAY {{ day }}</p>
  <div class="text">
    {% if redact %}{{ content | replace(redact, '<span class="redacted">' + redact + '</span>') | safe }}
    {% else %}{{ content | safe }}{% endif %}
  </div>
  <p class="actions">
    <a href="https://www.tiktok.com/@tarflog">DISCUSSION: TIKTOK</a>
    <a href="https://t.me/tarflog">TELEGRAM</a>
  </p>
  {% set entries = collections.log %}
  {% for e in entries %}{% if e.url == page.url %}
    {% set nxt = entries[loop.index0 - 1] %}
    {% set prv = entries[loop.index0 + 1] %}
    <nav class="pager">
      <span>{% if prv %}<a href="{{ prv.url | url }}">← {{ prv.data.file }}</a>{% endif %}</span>
      <span>{% if nxt %}<a href="{{ nxt.url | url }}">{{ nxt.data.file }} →</a>{% endif %}</span>
    </nav>
  {% endif %}{% endfor %}
</main>
