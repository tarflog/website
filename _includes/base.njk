<!doctype html>
<html lang="en" data-theme="terminal">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% if title %}{{ title }} · {% endif %}{{ site.name }}</title>
<meta name="description" content="{{ description or site.tagline }}">
<link rel="icon" type="image/svg+xml" href="{{ '/assets/img/favicon.svg' | url }}">
<link rel="alternate" type="application/rss+xml" title="{{ site.name }}" href="{{ '/feed.xml' | url }}">
<link rel="stylesheet" href="{{ '/assets/css/site.css' | url }}">
</head>
<body>
<header class="site">
  <div class="wrap site-bar">
    <a class="brand" href="{{ '/' | url }}">
      <svg width="26" height="26" viewBox="0 0 120 120" aria-hidden="true">
        <circle cx="60" cy="60" r="52" fill="none" stroke="var(--accent)" stroke-width="6" stroke-dasharray="2 10"/>
        <line x1="26" y1="60" x2="94" y2="60" stroke="var(--text)" stroke-width="7" stroke-linecap="round"/>
        <circle cx="74" cy="60" r="8" fill="var(--star)"/>
      </svg>
      <b>TARF·LOG</b>
    </a>
    <nav class="main" aria-label="Sections">
      <a href="{{ '/' | url }}" {% if nav == 'log' %}aria-current="page"{% endif %}>THE LOG</a>
      <a href="{{ '/archive/' | url }}" {% if nav == 'archive' %}aria-current="page"{% endif %}>REGISTRY</a>
      <a href="{{ '/subject/' | url }}" {% if nav == 'subject' %}aria-current="page"{% endif %}>DOSSIER</a>
      <a href="{{ '/channels/' | url }}" {% if nav == 'channels' %}aria-current="page"{% endif %}>CHANNELS</a>
    </nav>
  </div>
</header>

{{ content | safe }}

<footer class="site">
  <svg style="display:none" aria-hidden="true">
    <symbol id="i-tiktok" viewBox="0 0 24 24"><path d="M14 4v9.5a3.5 3.5 0 1 1-3.5-3.5M14 4c.4 2.3 2.2 4 4.5 4.2"/></symbol>
    <symbol id="i-youtube" viewBox="0 0 24 24"><rect x="3" y="6.5" width="18" height="11" rx="3"/><path d="M10.5 9.75v4.5l4-2.25z" fill="currentColor" stroke="none"/></symbol>
    <symbol id="i-instagram" viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="4.5"/><circle cx="12" cy="12" r="3.5"/><circle cx="16.8" cy="7.2" r="1" fill="currentColor" stroke="none"/></symbol>
    <symbol id="i-x" viewBox="0 0 24 24"><path d="M5.5 5.5l13 13M18.5 5.5l-13 13"/></symbol>
    <symbol id="i-telegram" viewBox="0 0 24 24"><path d="M20.5 5L4.2 11.2c-.6.25-.55 1.1.1 1.3l4.3 1.35 1.6 4.6c.2.6 1 .7 1.4.2l2.1-2.6 4.1 2.9c.5.35 1.2.05 1.3-.55L20.5 5z"/></symbol>
    <symbol id="i-rss" viewBox="0 0 24 24"><circle cx="6.2" cy="17.8" r="1.6" fill="currentColor" stroke="none"/><path d="M4.5 11.2a8.3 8.3 0 0 1 8.3 8.3M4.5 5.2a14.3 14.3 0 0 1 14.3 14.3"/></symbol>
  </svg>
  <div class="wrap foot-row">
    <img class="badgephoto" src="{{ '/assets/img/badge-macro.jpg' | url }}" alt="Expedition badge: a horizontal line with an orange dot." loading="lazy">
    <span>{{ site.email }}</span>
    <span class="foot-icons">
    {% for c in site.channels %}<a class="icon" href="{{ c.url }}" target="_blank" rel="noopener me" aria-label="{{ c.label }} — {{ c.handle }}" title="{{ c.label }} · {{ c.handle }}"><svg><use href="#i-{{ c.label | lower }}"/></svg></a>{% endfor %}
    <a class="icon" href="{{ '/feed.xml' | url }}" aria-label="RSS feed" title="RSS"><svg><use href="#i-rss"/></svg></a>
    </span>
    <a class="cats" href="{{ '/cats/' | url }}">cats</a>
  </div>
</footer>
{% if site.cfBeacon %}<!-- Cloudflare Web Analytics --><script type="module" src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "{{ site.cfBeacon }}"}'></script>{% endif %}
</body>
</html>
